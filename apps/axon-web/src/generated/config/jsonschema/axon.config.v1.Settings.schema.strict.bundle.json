{
  "$defs": {
    "axon.config.v1.AppearanceDefaults.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "accent_color": {
          "enum": [
            "ACCENT_COLOR_UNSPECIFIED",
            "ACCENT_COLOR_BLUE",
            "ACCENT_COLOR_GREEN",
            "ACCENT_COLOR_AMBER"
          ],
          "title": "Accent Color",
          "type": "string"
        },
        "density": {
          "enum": [
            "APPEARANCE_DENSITY_UNSPECIFIED",
            "APPEARANCE_DENSITY_COMPACT",
            "APPEARANCE_DENSITY_COMFORTABLE"
          ],
          "title": "Appearance Density",
          "type": "string"
        },
        "monospace_font": {
          "maxLength": 80,
          "minLength": 1,
          "type": "string"
        },
        "reduce_motion": {
          "type": "boolean"
        },
        "theme": {
          "enum": [
            "APPEARANCE_THEME_UNSPECIFIED",
            "APPEARANCE_THEME_SYSTEM",
            "APPEARANCE_THEME_LIGHT",
            "APPEARANCE_THEME_DARK"
          ],
          "title": "Appearance Theme",
          "type": "string"
        }
      },
      "required": [
        "theme",
        "density",
        "accent_color",
        "reduce_motion",
        "monospace_font"
      ],
      "title": "Appearance Defaults",
      "type": "object"
    },
    "axon.config.v1.EditorDefaults.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "format_on_run": {
          "type": "boolean"
        },
        "keymap": {
          "enum": [
            "EDITOR_KEYMAP_UNSPECIFIED",
            "EDITOR_KEYMAP_DEFAULT",
            "EDITOR_KEYMAP_VIM"
          ],
          "title": "Editor Keymap",
          "type": "string"
        },
        "starter_sql": {
          "maxLength": 20000,
          "type": "string"
        },
        "tab_size": {
          "maximum": 8,
          "minimum": 2,
          "type": "integer"
        },
        "word_wrap": {
          "type": "boolean"
        }
      },
      "required": [
        "keymap",
        "tab_size",
        "word_wrap",
        "format_on_run",
        "starter_sql"
      ],
      "title": "Editor Defaults",
      "type": "object"
    },
    "axon.config.v1.ExecutionDefaults.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "prefer_browser_runtime": {
          "type": "boolean"
        },
        "preview_row_limit": {
          "maximum": 10000,
          "minimum": 1,
          "type": "integer"
        },
        "query_timeout_ms": {
          "maximum": 600000,
          "minimum": 1000,
          "type": "integer"
        },
        "target": {
          "enum": [
            "EXECUTION_TARGET_UNSPECIFIED",
            "EXECUTION_TARGET_BROWSER",
            "EXECUTION_TARGET_NATIVE",
            "EXECUTION_TARGET_AUTO"
          ],
          "title": "Execution Target",
          "type": "string"
        }
      },
      "required": [
        "target",
        "preview_row_limit",
        "query_timeout_ms",
        "prefer_browser_runtime"
      ],
      "title": "Execution Defaults",
      "type": "object"
    },
    "axon.config.v1.Settings.schema.strict.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "appearance": {
          "$ref": "#/$defs/axon.config.v1.AppearanceDefaults.schema.strict.json"
        },
        "editor": {
          "$ref": "#/$defs/axon.config.v1.EditorDefaults.schema.strict.json"
        },
        "execution": {
          "$ref": "#/$defs/axon.config.v1.ExecutionDefaults.schema.strict.json"
        }
      },
      "title": "Settings",
      "type": "object"
    }
  },
  "$id": "axon.config.v1.Settings.schema.strict.bundle.json",
  "$ref": "#/$defs/axon.config.v1.Settings.schema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
