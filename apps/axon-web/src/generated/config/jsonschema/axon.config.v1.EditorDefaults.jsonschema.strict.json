{
  "$id": "axon.config.v1.EditorDefaults.jsonschema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "formatOnRun": {
      "type": "boolean"
    },
    "keymap": {
      "enum": [
        "EDITOR_KEYMAP_UNSPECIFIED",
        "EDITOR_KEYMAP_DEFAULT",
        "EDITOR_KEYMAP_VIM"
      ],
      "title": "Editor Keymap",
      "type": "string"
    },
    "starterSql": {
      "maxLength": 20000,
      "type": "string"
    },
    "tabSize": {
      "maximum": 8,
      "minimum": 2,
      "type": "integer"
    },
    "wordWrap": {
      "type": "boolean"
    }
  },
  "required": [
    "keymap",
    "tabSize",
    "wordWrap",
    "formatOnRun",
    "starterSql"
  ],
  "title": "Editor Defaults",
  "type": "object"
}
