{
  "$defs": {
    "axon.config.v1.AppearanceDefaults.jsonschema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "patternProperties": {
        "^(accent_color)$": {
          "anyOf": [
            {
              "pattern": "^ACCENT_COLOR_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "ACCENT_COLOR_BLUE",
                "ACCENT_COLOR_GREEN",
                "ACCENT_COLOR_AMBER"
              ],
              "type": "string"
            },
            {
              "maximum": 3,
              "minimum": 0,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Accent Color"
        },
        "^(monospace_font)$": {
          "default": "",
          "maxLength": 80,
          "minLength": 1,
          "type": "string"
        },
        "^(reduce_motion)$": {
          "default": false,
          "type": "boolean"
        }
      },
      "properties": {
        "accentColor": {
          "anyOf": [
            {
              "pattern": "^ACCENT_COLOR_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "ACCENT_COLOR_BLUE",
                "ACCENT_COLOR_GREEN",
                "ACCENT_COLOR_AMBER"
              ],
              "type": "string"
            },
            {
              "maximum": 3,
              "minimum": 0,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Accent Color"
        },
        "density": {
          "anyOf": [
            {
              "pattern": "^APPEARANCE_DENSITY_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "APPEARANCE_DENSITY_COMPACT",
                "APPEARANCE_DENSITY_COMFORTABLE"
              ],
              "type": "string"
            },
            {
              "maximum": 2,
              "minimum": 0,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Appearance Density"
        },
        "monospaceFont": {
          "default": "",
          "maxLength": 80,
          "minLength": 1,
          "type": "string"
        },
        "reduceMotion": {
          "default": false,
          "type": "boolean"
        },
        "theme": {
          "anyOf": [
            {
              "pattern": "^APPEARANCE_THEME_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "APPEARANCE_THEME_SYSTEM",
                "APPEARANCE_THEME_LIGHT",
                "APPEARANCE_THEME_DARK"
              ],
              "type": "string"
            },
            {
              "maximum": 3,
              "minimum": 0,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Appearance Theme"
        }
      },
      "title": "Appearance Defaults",
      "type": "object"
    }
  },
  "$id": "axon.config.v1.AppearanceDefaults.jsonschema.bundle.json",
  "$ref": "#/$defs/axon.config.v1.AppearanceDefaults.jsonschema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
