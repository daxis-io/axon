{
  "$defs": {
    "axon.config.v1.AppearanceDefaults.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "patternProperties": {
        "^(accentColor)$": {
          "anyOf": [
            {
              "pattern": "^ACCENT_COLOR_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "ACCENT_COLOR_BLUE",
                "ACCENT_COLOR_GREEN",
                "ACCENT_COLOR_AMBER"
              ],
              "type": "string"
            },
            {
              "maximum": 3,
              "minimum": 0,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Accent Color"
        },
        "^(monospaceFont)$": {
          "default": "",
          "maxLength": 80,
          "minLength": 1,
          "type": "string"
        },
        "^(reduceMotion)$": {
          "default": false,
          "type": "boolean"
        }
      },
      "properties": {
        "accent_color": {
          "anyOf": [
            {
              "pattern": "^ACCENT_COLOR_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "ACCENT_COLOR_BLUE",
                "ACCENT_COLOR_GREEN",
                "ACCENT_COLOR_AMBER"
              ],
              "type": "string"
            },
            {
              "maximum": 3,
              "minimum": 0,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Accent Color"
        },
        "density": {
          "anyOf": [
            {
              "pattern": "^APPEARANCE_DENSITY_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "APPEARANCE_DENSITY_COMPACT",
                "APPEARANCE_DENSITY_COMFORTABLE"
              ],
              "type": "string"
            },
            {
              "maximum": 2,
              "minimum": 0,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Appearance Density"
        },
        "monospace_font": {
          "default": "",
          "maxLength": 80,
          "minLength": 1,
          "type": "string"
        },
        "reduce_motion": {
          "default": false,
          "type": "boolean"
        },
        "theme": {
          "anyOf": [
            {
              "pattern": "^APPEARANCE_THEME_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "APPEARANCE_THEME_SYSTEM",
                "APPEARANCE_THEME_LIGHT",
                "APPEARANCE_THEME_DARK"
              ],
              "type": "string"
            },
            {
              "maximum": 3,
              "minimum": 0,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Appearance Theme"
        }
      },
      "title": "Appearance Defaults",
      "type": "object"
    },
    "axon.config.v1.EditorDefaults.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "patternProperties": {
        "^(formatOnRun)$": {
          "default": false,
          "type": "boolean"
        },
        "^(starterSql)$": {
          "default": "",
          "maxLength": 20000,
          "type": "string"
        },
        "^(tabSize)$": {
          "anyOf": [
            {
              "maximum": 8,
              "minimum": 2,
              "type": "integer"
            },
            {
              "pattern": "^[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "^(wordWrap)$": {
          "default": false,
          "type": "boolean"
        }
      },
      "properties": {
        "format_on_run": {
          "default": false,
          "type": "boolean"
        },
        "keymap": {
          "anyOf": [
            {
              "pattern": "^EDITOR_KEYMAP_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "EDITOR_KEYMAP_DEFAULT",
                "EDITOR_KEYMAP_VIM"
              ],
              "type": "string"
            },
            {
              "maximum": 2,
              "minimum": 0,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Editor Keymap"
        },
        "starter_sql": {
          "default": "",
          "maxLength": 20000,
          "type": "string"
        },
        "tab_size": {
          "anyOf": [
            {
              "maximum": 8,
              "minimum": 2,
              "type": "integer"
            },
            {
              "pattern": "^[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "word_wrap": {
          "default": false,
          "type": "boolean"
        }
      },
      "title": "Editor Defaults",
      "type": "object"
    },
    "axon.config.v1.ExecutionDefaults.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "patternProperties": {
        "^(preferBrowserRuntime)$": {
          "default": false,
          "type": "boolean"
        },
        "^(previewRowLimit)$": {
          "anyOf": [
            {
              "maximum": 10000,
              "minimum": 1,
              "type": "integer"
            },
            {
              "pattern": "^[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "^(queryTimeoutMs)$": {
          "anyOf": [
            {
              "maximum": 600000,
              "minimum": 1000,
              "type": "integer"
            },
            {
              "pattern": "^[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        }
      },
      "properties": {
        "prefer_browser_runtime": {
          "default": false,
          "type": "boolean"
        },
        "preview_row_limit": {
          "anyOf": [
            {
              "maximum": 10000,
              "minimum": 1,
              "type": "integer"
            },
            {
              "pattern": "^[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "query_timeout_ms": {
          "anyOf": [
            {
              "maximum": 600000,
              "minimum": 1000,
              "type": "integer"
            },
            {
              "pattern": "^[0-9]+$",
              "type": "string"
            }
          ],
          "default": 0
        },
        "target": {
          "anyOf": [
            {
              "pattern": "^EXECUTION_TARGET_UNSPECIFIED$",
              "type": "string"
            },
            {
              "enum": [
                "EXECUTION_TARGET_BROWSER",
                "EXECUTION_TARGET_NATIVE",
                "EXECUTION_TARGET_AUTO"
              ],
              "type": "string"
            },
            {
              "maximum": 3,
              "minimum": 0,
              "type": "integer"
            }
          ],
          "default": 0,
          "title": "Execution Target"
        }
      },
      "title": "Execution Defaults",
      "type": "object"
    },
    "axon.config.v1.Settings.schema.json": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "additionalProperties": false,
      "properties": {
        "appearance": {
          "$ref": "#/$defs/axon.config.v1.AppearanceDefaults.schema.json"
        },
        "editor": {
          "$ref": "#/$defs/axon.config.v1.EditorDefaults.schema.json"
        },
        "execution": {
          "$ref": "#/$defs/axon.config.v1.ExecutionDefaults.schema.json"
        }
      },
      "title": "Settings",
      "type": "object"
    }
  },
  "$id": "axon.config.v1.Settings.schema.bundle.json",
  "$ref": "#/$defs/axon.config.v1.Settings.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
