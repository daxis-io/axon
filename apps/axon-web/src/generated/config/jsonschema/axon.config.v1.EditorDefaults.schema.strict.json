{
  "$id": "axon.config.v1.EditorDefaults.schema.strict.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "format_on_run": {
      "type": "boolean"
    },
    "keymap": {
      "enum": [
        "EDITOR_KEYMAP_UNSPECIFIED",
        "EDITOR_KEYMAP_DEFAULT",
        "EDITOR_KEYMAP_VIM"
      ],
      "title": "Editor Keymap",
      "type": "string"
    },
    "starter_sql": {
      "maxLength": 20000,
      "type": "string"
    },
    "tab_size": {
      "maximum": 8,
      "minimum": 2,
      "type": "integer"
    },
    "word_wrap": {
      "type": "boolean"
    }
  },
  "required": [
    "keymap",
    "tab_size",
    "word_wrap",
    "format_on_run",
    "starter_sql"
  ],
  "title": "Editor Defaults",
  "type": "object"
}
